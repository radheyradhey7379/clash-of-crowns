# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase Admin (Server-side)
FIREBASE_SERVICE_ACCOUNT=

# Rust Backend Configuration (Module 1.1)
RUST_BACKED_PORT=3001
JWT_SECRET=your_jwt_secret_key_here
POSTGRES_URL=postgres://user:password@localhost:5432/chess_db
REDIS_URL=redis://127.0.0.1:6379

# Monitoring (Module 5.1)
SENTRY_DSN=https://your_sentry_dsn_here

# Feature Flags (v1.0)
VITE_ENABLE_MULTIPLAYER=true
VITE_ENABLE_RUST_REALTIME=true
VITE_ENABLE_RANKED_ARENA=false
VITE_ENABLE_SOCIAL_POKE=true
VITE_ENABLE_CHALLENGE_MATCH=false
VITE_ENABLE_TOURNAMENTS=false

# Render Live Endpoints
VITE_API_BASE_URL=
VITE_REALTIME_HTTP_URL=
VITE_REALTIME_WS_URL=

# Firebase Web Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=
