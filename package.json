{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "build:native": "npx vite build && npx shx rm -rf AndroidNativeApp/app/src/main/assets/www && npx shx mkdir -p AndroidNativeApp/app/src/main/assets/www && npx shx cp -r dist/* AndroidNativeApp/app/src/main/assets/www/",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "security:scan": "node scripts/security/security-scan.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/status-bar": "^8.0.2",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@google/genai": "^1.49.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@stripe/stripe-js": "^9.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/dompurify": "^3.0.5",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.546.0",
    "modern-screenshot": "^4.6.8",
    "motion": "^12.23.24",
